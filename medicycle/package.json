{
  "name": "medicycle-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:buyer": "npm run dev -w apps/buyer",
    "dev:seller": "npm run dev -w apps/seller",
    "dev:admin": "npm run dev -w apps/admin",
    "build:buyer": "npm run build -w apps/buyer",
    "build:seller": "npm run build -w apps/seller",
    "build:admin": "npm run build -w apps/admin",
    "build:all": "npm run build -w apps/buyer && npm run build -w apps/seller && npm run build -w apps/admin"
  }
}
